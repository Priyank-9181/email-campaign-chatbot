# Set true for local demo without MySQL (SQLite file: ./email_agent.db)
USE_SQLITE=false

# Agent tuning (optional)
# AGENT_TEMPERATURE=0.35
# AGENT_MAX_ITERATIONS=10
# AGENT_MAX_EXECUTION_SEC=150
# OPENROUTER_TIMEOUT_SEC=120
# OPENROUTER_MAX_RETRIES=1
# CHAT_HISTORY_MAX_TURNS=15   # prior user/agent pairs loaded into the agent for context

OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Must support tool/function calling (agent uses tools). Examples:
# openai/gpt-4o-mini, anthropic/claude-3.5-haiku, google/gemini-2.0-flash-001
OPENROUTER_MODEL=openai/gpt-4o-mini

# MySQL
DB_URL=mysql+pymysql://root:password@localhost:3306/email_agent_db

# Email Sending (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SENDER_NAME=AI Email Agent
